erDiagram
    %% ═══════════════════════════════════════
    %% PHONOLOGY LAYER
    %% ═══════════════════════════════════════

    tone {
        smallint id PK
        varchar name "ngang sac huyen hoi nga nang"
        varchar diacritic
        varchar ipa_contour
    }

    initial_consonant {
        smallint id PK
        varchar grapheme "b ch d gi kh ng ph th tr..."
        varchar ipa_north
        varchar ipa_south
    }

    vowel_nucleus {
        smallint id PK
        varchar grapheme "a e i o u ơ ư..."
        varchar ipa
        varchar vowel_type "mono di tri"
    }

    final_consonant {
        smallint id PK
        varchar grapheme "c m n ng p t..."
        varchar ipa
    }

    syllable {
        int id PK
        varchar text UK "e.g. nguyen khong"
        int initial_id FK
        int nucleus_id FK
        int final_id FK
        int tone_id FK
        varchar ipa
        int frequency_rank
    }

    syllable }o--|| tone : "has"
    syllable }o--|| initial_consonant : "starts with"
    syllable }o--|| vowel_nucleus : "contains"
    syllable }o--|| final_consonant : "ends with"

    %% ═══════════════════════════════════════
    %% DICTIONARY LAYER
    %% ═══════════════════════════════════════

    word {
        int id PK
        varchar text "e.g. hoc sinh"
        varchar slug UK
        smallint syllable_count
        enum origin "native sino_viet french english"
        varchar han_viet "e.g. 學生"
        enum cefr "A1-C2"
        boolean is_published
    }

    word_syllable {
        int word_id FK
        int syllable_id FK
        smallint position
    }

    sense {
        int id PK
        int word_id FK
        enum pos "noun verb adj adv classifier..."
        text definition_vi
        text definition_en
        enum region "standard north central south"
        varchar register "formal slang literary..."
        varchar semantic_field
    }

    example_sentence {
        int id PK
        int sense_id FK
        text sentence_vi
        text sentence_en
        text literal_en "word-by-word gloss"
    }

    word_relationship {
        int id PK
        int source_word_id FK
        int target_word_id FK
        varchar type "synonym antonym variant..."
    }

    classifier_noun {
        int id PK
        int classifier_word_id FK
        int noun_word_id FK
        boolean is_default
    }

    pronunciation_variant {
        int id PK
        int word_id FK
        enum region
        varchar ipa
        text audio_url
    }

    word ||--o{ word_syllable : "composed of"
    syllable ||--o{ word_syllable : "appears in"
    word ||--o{ sense : "has meanings"
    sense ||--o{ example_sentence : "illustrated by"
    word ||--o{ word_relationship : "source"
    word ||--o{ word_relationship : "target"
    word ||--o{ classifier_noun : "classified by"
    word ||--o{ pronunciation_variant : "pronounced as"

    %% ═══════════════════════════════════════
    %% GRAMMAR LAYER
    %% ═══════════════════════════════════════

    grammar_point {
        int id PK
        varchar slug UK
        varchar title_vi
        varchar title_en
        enum cefr
        varchar category "particles tense classifiers..."
        jsonb explanation
    }

    grammar_example {
        int id PK
        int grammar_point_id FK
        text sentence_vi
        text sentence_en
        jsonb word_gloss
    }

    grammar_word {
        int grammar_point_id FK
        int word_id FK
        varchar role
    }

    grammar_point ||--o{ grammar_example : "demonstrated by"
    grammar_point ||--o{ grammar_word : "uses"
    word ||--o{ grammar_word : "featured in"

    %% ═══════════════════════════════════════
    %% TEXTBOOK CMS LAYER
    %% ═══════════════════════════════════════

    textbook {
        int id PK
        varchar title
        varchar slug UK
        enum target_cefr
        varchar target_audience
        varchar language_pair "vi-en vi-zh..."
        int created_by FK
        boolean is_published
    }

    unit {
        int id PK
        int textbook_id FK
        varchar title
        smallint sort_order
    }

    lesson {
        int id PK
        int unit_id FK
        varchar title
        enum cefr
        smallint estimated_minutes
        smallint sort_order
    }

    content_block {
        int id PK
        int lesson_id FK
        enum block_type "vocab dialogue grammar exercise..."
        varchar title
        jsonb content "structured payload"
        jsonb metadata "AI tags and hints"
        smallint sort_order
    }

    block_word {
        int block_id FK
        int word_id FK
    }

    block_grammar {
        int block_id FK
        int grammar_point_id FK
    }

    textbook ||--o{ unit : "contains"
    unit ||--o{ lesson : "contains"
    lesson ||--o{ content_block : "contains"
    content_block ||--o{ block_word : "references"
    word ||--o{ block_word : "used in"
    content_block ||--o{ block_grammar : "teaches"
    grammar_point ||--o{ block_grammar : "taught in"

    %% ═══════════════════════════════════════
    %% USERS AND REVISIONS
    %% ═══════════════════════════════════════

    app_user {
        int id PK
        varchar email UK
        varchar display_name
        enum role "admin editor teacher contributor viewer"
        boolean is_active
    }

    permission {
        int id PK
        int user_id FK
        varchar resource_type
        int resource_id "nullable"
        boolean can_edit
        boolean can_publish
    }

    revision {
        int id PK
        varchar entity_type
        int entity_id
        int user_id FK
        varchar action "create update delete"
        jsonb diff
        jsonb snapshot
        enum status "draft pending approved rejected"
        int reviewed_by FK
    }

    pending_edit {
        int id PK
        varchar entity_type
        int entity_id
        int user_id FK
        jsonb proposed_data
        enum status
        int reviewed_by FK
    }

    tag {
        int id PK
        varchar name UK
        varchar category "topic skill theme"
    }

    entity_tag {
        int tag_id FK
        varchar entity_type
        int entity_id
    }

    app_user ||--o{ textbook : "creates"
    app_user ||--o{ permission : "granted"
    app_user ||--o{ revision : "authored"
    app_user ||--o{ pending_edit : "proposed"
    tag ||--o{ entity_tag : "applied to"
