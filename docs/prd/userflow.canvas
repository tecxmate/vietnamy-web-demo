		{"id":"pm_pitch","type":"text","text":"🎤 **Tone Pitch Training** `/practice/pitch`\nRecord → DTW scoring vs. native\nAI ASR feedback (AWS/Azure Phase 2)\n*Premium feature*","x":530,"y":-485,"width":290,"height":85,"color":"2"},
